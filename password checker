
a=input("ENTER YOUR PASSWORD")
up=0
lo=0
dg=0
sp=0
if (len(a) > 7):
    for i in a:
        if (i.isupper()):
            up=up+1
        elif (i.islower()):
            lo=lo+1
        elif (i.isdigit()):
            dg=dg+1
        else:
            sp=sp+1
    
    if (up>0 and lo>0 and dg>0 and sp>0 ):
        
        
        print("PASSWORD SAVED SUCCESSFULLY!!!")
    
    else:
        print("CHOOSE RIGHT PASSWORD WITH ALL THE CONDITIONS")
else:
    print("ENTER STRONG PASSWORD")
    
